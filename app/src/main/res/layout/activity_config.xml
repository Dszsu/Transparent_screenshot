<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="?android:attr/colorBackground">

        <!-- 顶部应用信息栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:clickable="false">

            <ImageView
                android:id="@+id/iv_app_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="应用图标" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_app_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="?android:attr/textColorPrimary" />

                <TextView
                    android:id="@+id/tv_app_package"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginVertical="12dp" />

        <!-- 功能开关列表 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:divider="?android:attr/listDivider"
            android:showDividers="middle">

            <!-- enable_skip_screenshot -->
            <LinearLayout style="@style/ConfigItemRow">
                <TextView style="@style/ConfigItemLabel" android:text="启用 skipScreenshot" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_disable_skip_screenshot"
                    style="@style/ConfigItemSwitch" />
            </LinearLayout>

            <LinearLayout style="@style/ConfigItemRow">
                <TextView style="@style/ConfigItemLabel" android:text="去除阴影遮罩" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_dim_behind"
                    style="@style/ConfigItemSwitch" />
            </LinearLayout>

            <LinearLayout style="@style/ConfigItemRow">
                <TextView style="@style/ConfigItemLabel" android:text="窗口不获取焦点" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_no_focus"
                    style="@style/ConfigItemSwitch" />
            </LinearLayout>

            <LinearLayout style="@style/ConfigItemRow">
                <TextView style="@style/ConfigItemLabel" android:text="启用 MagicFlags" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_magic_flags"
                    style="@style/ConfigItemSwitch" />
            </LinearLayout>

            <LinearLayout style="@style/ConfigItemRow">
                <TextView style="@style/ConfigItemLabel" android:text="隐藏后台卡片" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_hide_recent_card"
                    style="@style/ConfigItemSwitch" />
            </LinearLayout>

            <!-- 窗口标题 开关 + 模式下拉 + 提示 + 自定义输入 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="8dp">

                <LinearLayout style="@style/ConfigItemRow">
                    <TextView style="@style/ConfigItemLabel" android:text="修改窗口标题为" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_window_title"
                        style="@style/ConfigItemSwitch" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_title_picker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:enabled="false"
                    android:alpha="0.5">

                    <Spinner
                        android:id="@+id/spinner_title_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/text_global_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                    <EditText
                        android:id="@+id/edit_custom_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="输入自定义标题"
                        android:enabled="true"
                        android:visibility="gone"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>