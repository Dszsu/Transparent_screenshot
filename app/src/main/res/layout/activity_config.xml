<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="?android:attr/colorBackground"
        android:clipToPadding="false">

        <!-- 顶部应用信息栏 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:background="?attr/colorSurface"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:clickable="false">

                <ImageView
                    android:id="@+id/iv_app_icon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/appicon"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_app_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:id="@+id/tv_app_package"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 1. 启用窗口隐藏方案1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="4dp"
            android:background="?attr/colorSurface"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="16sp"
                        android:text="@string/skipscreenshot"
                        android:textColor="?android:attr/textColorPrimary" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_disable_skip_screenshot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:importantForAccessibility="no" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_skip_screenshot"
                    android:textSize="12sp"
                    android:textColor="@color/desc_text_gray"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:layout_marginTop="-10dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 2. 去除阴影遮罩 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="?attr/colorSurface"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:text="@string/dim0"
                    android:textColor="?android:attr/textColorPrimary" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_dim_behind"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:importantForAccessibility="no" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 3. 绕过焦点检查 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="?attr/colorSurface"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="16sp"
                        android:text="@string/magicflags"
                        android:textColor="?android:attr/textColorPrimary" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_magic_flags"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:importantForAccessibility="no" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_magic_flags"
                    android:textSize="12sp"
                    android:textColor="@color/desc_text_gray"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:layout_marginTop="-10dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 4. 隐藏最近任务界面 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="?attr/colorSurface"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="16sp"
                    android:text="@string/card"
                    android:textColor="?android:attr/textColorPrimary" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_hide_recent_card"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:importantForAccessibility="no" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 5. 窗口标题 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="4dp"
            android:background="?attr/colorSurface"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="16sp"
                        android:text="@string/title"
                        android:textColor="?android:attr/textColorPrimary" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_window_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:importantForAccessibility="no" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/desc_window_title"
                    android:textSize="12sp"
                    android:textColor="@color/desc_text_gray"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:layout_marginTop="-10dp" />

                <LinearLayout
                    android:id="@+id/layout_title_picker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:enabled="false"
                    android:alpha="0.5">

                    <Spinner
                        android:id="@+id/spinner_title_mode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/spinner_background"
                        android:popupBackground="@drawable/popup_background"
                        android:dropDownVerticalOffset="8dp"
                        android:padding="12dp" />

                    <TextView
                        android:id="@+id/text_global_hint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/desc_text_gray"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />

                    <EditText
                        android:id="@+id/edit_custom_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/user_title"
                        android:enabled="true"
                        android:visibility="gone"
                        android:inputType="textCapSentences"
                        android:autofillHints="no"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- WebView 提示（暗黄色） -->
        <TextView
            android:id="@+id/text_webview_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/webview_hint"
            android:textSize="12sp"
            android:textColor="#FFB8860B"
            android:visibility="gone"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="4dp" />
    </LinearLayout>
</ScrollView>